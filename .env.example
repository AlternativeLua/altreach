# Server: address to bind on (use 0.0.0.0 to accept connections on all interfaces)
BIND_ADDR=0.0.0.0:7878

# Client: address to connect to
# LAN:  use the Windows machine's local IP  e.g. 192.168.1.x:7878
# WAN:  use your public IP or DDNS hostname e.g. 123.45.67.89:7878
SERVER_ADDR=your_ip_here:7878

# Shared secret — change this to something strong before exposing to WAN
PASSWORD=yourpassword
